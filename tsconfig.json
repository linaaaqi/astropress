{
  "extends": "astro/tsconfigs/strictest",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/config": [
        "astropress.config"
      ],
      "@/*": [
        "src/*"
      ],
      "astro/*": [
        ".astro/*"
      ]
    }
  }
}
